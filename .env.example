# Gmail OAuth Credentials (Get from Google Cloud Console)
GMAIL_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session Configuration
SESSION_SECRET=generate_a_random_32_character_string_here

# Database Configuration
DATABASE_PATH=./data/database.sqlite

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
ENCRYPTION_KEY=generate_a_32_byte_hex_string_here
